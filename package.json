{
  "name": "your-space",
  "version": "1.3.0",
  "productName": "YourSpace",
  "description": "YourSpace - app launcher and tracker",
  "author": "Uewque",
  "packageManager": "yarn@4.12.0",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"yarn dev:electron\" --kill-others --success first",
    "dev:electron": "electron-vite dev",
    "server": "tsx watch server/index.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "yarn build && electron-builder",
    "push": "yarn build && electron-builder --publish always",
    "release": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "prisma:generate": "prisma generate",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "@prisma/extension-accelerate": "^3.0.1",
    "@vueuse/core": "^14.2.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash-es": "^4.17.23",
    "lucide-vue-next": "^0.575.0",
    "marked": "^17.0.4",
    "node-vibrant": "^4.0.4",
    "pinia": "^3.0.4",
    "vite": "^7.3.1",
    "vue": "^3.5.29",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash-es": "^4",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.6.1",
    "electron-builder": "26.8.1",
    "electron-vite": "^5.0.0",
    "env-cmd": "^11.0.0",
    "happy-dom": "^20.8.3",
    "prisma": "^7.4.2",
    "sass": "^1.97.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.uewque.yourspace",
    "productName": "YourSpace",
    "directories": {
      "output": "dist_electron"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "public/logo",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "!dist_electron"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YourSpace",
      "include": "installer.nsh",
      "license": "license.txt",
      "installerIcon": "public/logo/logo.ico",
      "uninstallerIcon": "public/logo/logo.ico",
      "uninstallDisplayName": "${productName}",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "public/logo/logo.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "repo": "YourSpace",
      "owner": "uewquewqueqwue",
      "private": true,
      "releaseType": "release",
      "vPrefixedTagName": true
    }
  }
}
