// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  apps      UserApp[]
  todoFolders TodoFolder[]
  todoTags    TodoTag[]
  todoItems   UserTodo[]
}

model AppCatalog {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userApps UserApp[]
}

model UserApp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  catalogId String
  catalog   AppCatalog @relation(fields: [catalogId], references: [id])
  
  path      String
  customName  String?
  customColor String?
  
  totalMinutes Int        @default(0)
  lastUsed     DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, path])
}

model AppVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  releaseDate DateTime @default(now())
  isRequired  Boolean  @default(false)
  minVersion  String?
  downloadUrl String?
  size        Int?
  changelog   String?
  
  patchNotes  PatchNote[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PatchNote {
  id          String        @id @default(cuid())
  versionId   String
  version     AppVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  
  icon        String        @default("✨")
  title       String        
  description String?       
  category    PatchCategory @default(FEATURE)
  order       Int           @default(0)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum PatchCategory {
  FEATURE
  IMPROVEMENT
  BUGFIX
  PERFORMANCE
  SECURITY
  OTHER
}

// TODOLIST

model TodoFolder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  icon        String?
  color       String?
  position    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  todos       UserTodo[]
  
  @@unique([userId, name])
}

model TodoTag {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  color       String?
  position    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  todos       UserTodoTag[]
  
  @@unique([userId, name])
}

model UserTodo {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  folderId    String?
  folder      TodoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  
  title       String
  description String?
  priority    ToDoPriority @default(MEDIUM)
  dueDate     DateTime?
  completed   Boolean  @default(false)
  completedAt DateTime?
  position    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        UserTodoTag[]
}

model UserTodoTag {
  id        String   @id @default(cuid())
  todoId    String
  todo      UserTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  tagId     String
  tag       TodoTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([todoId, tagId])
}

enum ToDoPriority {
  LOW
  MEDIUM
  HIGH
}