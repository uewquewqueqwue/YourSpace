// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  apps      UserApp[]
  todoFolders TodoFolder[]
  todoTags    TodoTag[]
  todoItems   UserTodo[]
  googleAccounts GoogleAccount[]
}

model AppCatalog {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userApps UserApp[]
}

model UserApp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  catalogId String
  catalog   AppCatalog @relation(fields: [catalogId], references: [id])
  
  path      String
  customName  String?
  customColor String?
  
  totalMinutes Int        @default(0)
  lastUsed     DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, path])
}

model AppVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  releaseDate DateTime @default(now())
  isRequired  Boolean  @default(false)
  minVersion  String?
  downloadUrl String?
  size        Int?
  changelog   String?
  
  patchNotes  PatchNote[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PatchNote {
  id          String        @id @default(cuid())
  versionId   String
  version     AppVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  
  icon        String        @default("✨")
  title       String        
  description String?       
  category    PatchCategory @default(FEATURE)
  order       Int           @default(0)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum PatchCategory {
  FEATURE
  IMPROVEMENT
  BUGFIX
  PERFORMANCE
  SECURITY
  OTHER
}

// TODOLIST

model TodoFolder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  color       String?
  position    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  todos       UserTodo[]
  
  @@unique([userId, name])
}

model TodoTag {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  color       String?
  position    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  todos       UserTodoTag[]
  
  @@unique([userId, name])
}

model UserTodo {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  folderId    String?
  folder      TodoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  
  title       String
  description String?
  priority    ToDoPriority @default(MEDIUM)
  dueDate     DateTime?
  completed   Boolean  @default(false)
  completedAt DateTime?
  position    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        UserTodoTag[]
}

model UserTodoTag {
  id        String   @id @default(cuid())
  todoId    String
  todo      UserTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  tagId     String
  tag       TodoTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([todoId, tagId])
}

enum ToDoPriority {
  LOW
  MEDIUM
  HIGH
}

// EMAIL AGGREGATOR

model GoogleAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  email         String
  accessToken   String   // Encrypted with AES-256
  refreshToken  String   // Encrypted with AES-256
  tokenExpiry   DateTime
  
  lastSyncAt    DateTime?
  syncStatus    SyncStatus @default(IDLE)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  emails        Email[]
  
  @@unique([userId, email])
  @@index([userId])
}

model Email {
  id            String   @id @default(cuid())
  
  accountId     String
  account       GoogleAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  gmailId       String   @unique  // Gmail message ID
  threadId      String?
  
  subject       String
  sender        String   // "Name <email@example.com>"
  recipient     String
  preview       String   @db.Text
  
  isRead        Boolean  @default(false)
  timestamp     DateTime
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([accountId, timestamp(sort: Desc)])
  @@index([isRead])
  @@index([gmailId])
}

enum SyncStatus {
  IDLE
  SYNCING
  ERROR
}