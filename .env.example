# Database Configuration
DATABASE_URL="your_database_url_here"

# GitHub Token for auto-updates
GH_TOKEN="your_github_token_here"

# JWT Secret for authentication (generate a strong random string)
JWT_SECRET="your_jwt_secret_here"

# OAuth Encryption Key for encrypting OAuth tokens
# Generate using: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY="your_oauth_encryption_key_here"

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Create OAuth client ID with type "Desktop app"
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Environment
NODE_ENV="development"

# Logging
LOG_LEVEL="info"
